# ── Slack ─────────────────────────────────────────────────────────────────────
# From: api.slack.com/apps → your app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...

# From: api.slack.com/apps → your app → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# From: api.slack.com/apps → your app → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=...

# ── Anthropic ─────────────────────────────────────────────────────────────────
# From: console.anthropic.com → API Keys
# Use the WORK account key (platform.claude.ai → API Keys section)
ANTHROPIC_API_KEY=sk-ant-...

# ── Notion ────────────────────────────────────────────────────────────────────
# From: notion.so → Settings → Connections → Develop or manage integrations
# Or from: notion.so/profile/integrations → New integration → Internal
NOTION_TOKEN=secret_...

# ── Google Drive + Sheets ──────────────────────────────────────────────────────
# Path to your Google Service Account JSON credentials file
# The service account needs:
#   - Google Drive API (drive.readonly scope) — for reading project folders
#   - Google Sheets API (spreadsheets scope) — for reading/writing budget table
# Share your budget spreadsheet with the service account email address.
GOOGLE_SERVICE_ACCOUNT_PATH=google_credentials.json

# ── Budget spreadsheet ─────────────────────────────────────────────────────────
# Master budget Google Spreadsheet ID (from the URL: docs.google.com/spreadsheets/d/ID/...)
# Default: 1Bu9ld8JiA7DtOgM8UM4WK91pM93Ct6udBZsnUQBBt5E
BUDGET_SPREADSHEET_ID=1Bu9ld8JiA7DtOgM8UM4WK91pM93Ct6udBZsnUQBBt5E

# ── Payment channel ────────────────────────────────────────────────────────────
# Slack channel ID where 1C payment notifications are posted (bs-slack-payment)
# Add the bot to this channel so it can auto-detect and process payments.
# To find channel ID: right-click channel → View channel details → bottom of page
PAYMENT_CHANNEL_ID=C0AT59F5F2P
